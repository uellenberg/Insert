//@check

const val1: u32 = used();

function main() -> u32 {
    let val: u32 = val1;
    val = addOne(val);
    addOne(15);
    used();
    let res: u32 = addOne(addOne(val));
    return res;
}

helper function used() -> u32 {
    return 10;
}

helper function unused() -> u32 {
    return 11;
}

inline function addOne(a: u32) -> u32 {
    return a + 1;
}
//@check

const WIDTH: i32 = 70;
const HEIGHT: i32 = 15;
const BALL_WIDTH: i32 = 3;
const BALL_HEIGHT: i32 = 2;
const PADDLE_WIDTH: i32 = 3;
const PADDLE_HEIGHT: i32 = 5;

// Higher values means it moves slower.
const ROBOT_SPEED: i32 = 3;

// Velocity of the jump.
const JUMP_HEIGHT: i32 = 3;

// Subtract 1 so the first run generates a centered and formatted output.
static ballX: i32 = binding ballXMarker (WIDTH / 2 - BALL_WIDTH / 2 - 1);
static ballY: i32 = binding ballYMarker (HEIGHT / 2 - BALL_HEIGHT / 2 - 1);
static ballSpeedX: i32 = binding ballSpeedXMarker (1);
static ballSpeedY: i32 = binding ballSpeedYMarker (1);

const STARTING_PADDLE_LEFT_X: i32 = 5;
const STARTING_PADDLE_RIGHT_X: i32 = WIDTH - PADDLE_WIDTH - STARTING_PADDLE_LEFT_X;

static paddleLeftX: i32 = binding paddleLeftXMarker (STARTING_PADDLE_LEFT_X);
static paddleLeftY: i32 = binding paddleLeftYMarker (ROBOT_SPEED * (HEIGHT / 2 - PADDLE_HEIGHT / 2));
static paddleRightX: i32 = binding paddleRightXMarker (STARTING_PADDLE_RIGHT_X);
static paddleRightY: i32 = binding paddleRightYMarker (HEIGHT / 2 - PADDLE_HEIGHT / 2);

// 0 = pong, [1, 5] = jump (each number is a different place),
// 6 = mandelbrot
static gameState: i32 = binding gameStateMarker (0);

static jumpHeights: [i32; 5] = [1, 3, 1, 4, 1];

static quineStr: &[string] = $quine;

const SPACE_CHAR: char = $quineSpace;
const LINE_CHAR: char = $quineLine;

import "std/print.int";
import "std/string.int";

static idx: i32 = 0;
// Offset 0 is the comma (optional), 1 is the opening quote, and one past the end of the string
// is the closing quote.
// It's 1 initially to avoid printing the comma for the first item.
static offset: i32 = 1;

/**
  * Tries to print a single character of the quine array, stepping idx and offset forward.
  * Returns true if two characters were printed (needed to escape chars).
  *
  * This uses recursion to skip an offset while still printing out a character in the end.
  */
helper function printQuineArrayChar() -> bool {
    offset = offset + 1;

    if offset == 1 {
        putchar(',');
        return false;
    }

    if offset == 2 {
        putchar('"');
        return false;
    }

    let c: char = quineStr[idx][offset - 3];

    if c == '\0' {
        putchar('"');
        offset = 0;
        idx = idx + 1;
        return false;
    }

    if c == '"' {
        putchar('\\');
        putchar('\"');
        return true;
    }

    if c == '\\' {
        putchar('\\');
        putchar('\\');
        return true;
    }

    if c != ' ' && c != '\n' {
        putchar(c);
        return false;
    }

    return printQuineArrayChar();
}

helper function printQuineArr() {
    // Printing the first character here helps keep the
    // backslashes at the end more consistent.
    printQuineArrayChar();
    putchar('\\');
    putchar('\n');
    // Separator.
    putchar('\\');
    putchar('\n');

    for let row: i32 = 0; row < HEIGHT; row = row + 1; {
        for let col: i32 = 0; col < WIDTH; col = col + 1; {
            if idx >= $quineLen || (col >= ballX && row >= ballY && col - ballX < BALL_WIDTH && row - ballY < BALL_HEIGHT)
               || (col >= paddleLeftX && row >= paddleLeftY / ROBOT_SPEED && col - paddleLeftX < PADDLE_WIDTH && row - paddleLeftY / ROBOT_SPEED < PADDLE_HEIGHT)
               || (col >= paddleRightX && row >= paddleRightY && col - paddleRightX < PADDLE_WIDTH && row - paddleRightY < PADDLE_HEIGHT)
            {
                putchar(' ');
            } else {
            if printQuineArrayChar() {
                    col = col + 1;
                }
            }
        }

        // Offset 0 means we aren't in a string literal,
        // so we need a backslash to continue it.
        if offset != 0 {
            putchar('\\');
        }
        putchar('\n');
    }

    // Separator.
    if offset != 0 {
        putchar('\\');
    }
    putchar('\n');

    // Print the remaining characters.
    while idx < $quineLen {
        printQuineArrayChar();
    }
}

helper function printQuineItem(s: string) {
    // This is the quine part of the string if it's completely
    // empty, except for spaces and newlines.
    let quinePart: bool = true;
    for let i: i32 = 0; s[i] != '\0'; i = i + 1; {
        if s[i] == $quineSpace {
            putchar(' ');
        } else if s[i] == $quineLine {
            putchar('\n');
        } else if s[i] != ' ' && s[i] != '\n' {
            quinePart = false;
            putchar(s[i]);
        }
    }

    if quinePart {
        printQuineArr();
    }
}

helper function printQuine1() {
    for let i: i32 = 0; i < $quineLen; i = i + 1; {
        if i != 0 {
            putchar(' ');
        }

        printQuineItem(quineStr[i]);
    }

    // A trailing newline is needed for valid C.
    putchar('\n');
}

helper function setQuineVar(index: i32, val: i32) {
    stringInto(val, &quineStr[index]);
}

inline function pongUpdates(argc: i32, argv: &[string]) {
    // Compute next ball position.
    ballX = ballX + ballSpeedX;
    ballY = ballY + ballSpeedY;

    // Paddle bounce.
    //
    // This is optimized for the sides that will actually be hit,
    // so if the ball hits the left paddle while moving right,
    // it will phase through.
    if (ballX == paddleLeftX && ballY + BALL_HEIGHT > paddleLeftY / ROBOT_SPEED && ballY < paddleLeftY / ROBOT_SPEED + PADDLE_HEIGHT)
       || (ballX + (BALL_WIDTH - 1) == paddleRightX && ballY + BALL_HEIGHT > paddleRightY && ballY < paddleRightY + PADDLE_HEIGHT)
    {
        ballX = ballX - ballSpeedX;
        ballSpeedX = -1 * ballSpeedX;
    }

    // Left and right walls means a player lost.
    if ballX < 0 || ballX > WIDTH - BALL_WIDTH {
        // The user won.
        if ballX < 0 {
            gameState = 1;
        }

        ballX = WIDTH / 2 - BALL_WIDTH / 2;
        ballY = HEIGHT / 2 - BALL_HEIGHT / 2;
    }

    // Top and bottom walls should bounce.
    if ballY < 0 || ballY > HEIGHT - BALL_HEIGHT {
        ballY = ballY - ballSpeedY;
        ballSpeedY = -1 * ballSpeedY;
    }

    // Compute paddle updates.

    if paddleLeftY / ROBOT_SPEED > HEIGHT - PADDLE_HEIGHT {
        paddleLeftY = paddleLeftY - ROBOT_SPEED;
    }

    if paddleRightY > HEIGHT - PADDLE_HEIGHT {
        paddleRightY = paddleRightY - 1;
    }

    if argc > 1 {
        if argv[1][0] == 'w' && paddleRightY > 0 {
            paddleRightY = paddleRightY - 1;
        }

        if argv[1][0] == 's' && paddleRightY < HEIGHT - PADDLE_HEIGHT {
            paddleRightY = paddleRightY + 1;
        }
    }

    let robotDistance: i32 = paddleLeftY / ROBOT_SPEED - ballY + (PADDLE_HEIGHT / 2 - BALL_HEIGHT / 2);
    if robotDistance < 0 {
        paddleLeftY = paddleLeftY + 1;
    }

    if robotDistance > 0 {
        paddleLeftY = paddleLeftY - 1;
    }
}

inline function jumpUpdates(argc: i32, argv: &[string]) {
    // Gravity.
    ballY = ballY + 1 - ballSpeedY;
    if ballSpeedY > 0 {
        ballSpeedY = ballSpeedY - 1;
    }

    // Jump handling.
    if ballY >= HEIGHT - BALL_HEIGHT {
        if argc > 1 && argv[1][0] == 'w' {
            ballSpeedY = JUMP_HEIGHT;
        }

        ballY = HEIGHT - BALL_HEIGHT;
    }

    // Transition the paddles down before we start moving them.
    // This means the distance between paddles changes depending on the
    // user and bot's starting positions, but not to a degree that
    // matters.
    if paddleLeftY / ROBOT_SPEED < HEIGHT - jumpHeights[gameState - 1] {
        paddleLeftY = paddleLeftY + ROBOT_SPEED;
    } else {
        paddleLeftX = paddleLeftX - 1;
    }

    if paddleRightY < HEIGHT - jumpHeights[gameState] {
        paddleRightY = paddleRightY + 1;
    } else {
        paddleRightX = paddleRightX - 1;
    }

    // Swap out paddles when they reach the edge of the screen.
    if paddleLeftX + PADDLE_WIDTH <= 0 {
        gameState = gameState + 1;
        if gameState < 6 {
            paddleLeftX = paddleRightX;
            paddleLeftY = paddleRightY * ROBOT_SPEED;
            paddleRightX = WIDTH;
            paddleRightY = HEIGHT - jumpHeights[gameState - 1];
        } else {
            gameState = 0;
            paddleLeftX = STARTING_PADDLE_LEFT_X;
            paddleRightX = STARTING_PADDLE_RIGHT_X;
            ballSpeedX = 1;
            ballSpeedY = 1;
        }
    }

    // If we collide with the paddle, restart.
    if (ballX + (BALL_WIDTH - 1) == paddleRightX && ballY + BALL_HEIGHT > paddleRightY && ballY < paddleRightY + PADDLE_HEIGHT)
       || (ballX + (BALL_WIDTH - 1) == paddleLeftX && ballY + BALL_HEIGHT > paddleLeftY / ROBOT_SPEED && ballY < paddleLeftY / ROBOT_SPEED + PADDLE_HEIGHT)
    {
        gameState = 1;
        paddleLeftX = STARTING_PADDLE_LEFT_X;
        paddleLeftY = ROBOT_SPEED * (HEIGHT - jumpHeights[0]);
        paddleRightX = STARTING_PADDLE_RIGHT_X;
        paddleRightY = HEIGHT - jumpHeights[1];
    }
}

function main(argc: i32, argv: &[string]) -> i32 {
    // Must be else if since they update gameState.
    if gameState == 0 {
        pongUpdates(argc, argv);
    } else if gameState < 6 {
        jumpUpdates(argc, argv);
    }

    setQuineVar(ballXMarker, ballX);
    setQuineVar(ballYMarker, ballY);
    setQuineVar(ballSpeedXMarker, ballSpeedX);
    setQuineVar(ballSpeedYMarker, ballSpeedY);
    setQuineVar(paddleLeftXMarker, paddleLeftX);
    setQuineVar(paddleLeftYMarker, paddleLeftY);
    setQuineVar(paddleRightXMarker, paddleRightX);
    setQuineVar(paddleRightYMarker, paddleRightY);
    setQuineVar(gameStateMarker, gameState);
    printQuine1();
}

//@check

const WIDTH: i32 = 70;
const HEIGHT: i32 = 15;
const BALL_RADIUS: i32 = 3;
const PADDLE_WIDTH: i32 = 3;
const PADDLE_HEIGHT: i32 = 6;

const PADDLE_LEFT_X: i32 = 5;
const PADDLE_RIGHT_X: i32 = WIDTH - PADDLE_WIDTH - PADDLE_LEFT_X;

static ballX: i32 = binding ballXMarker (WIDTH / 2 - BALL_RADIUS / 2);
static ballY: i32 = binding ballYMarker (HEIGHT / 2 - BALL_RADIUS / 2);
static ballSpeedX: i32 = binding ballSpeedXMarker (1);
static ballSpeedY: i32 = binding ballSpeedYMarker (1);

static paddleLeftY: i32 = binding paddleLeftYMarker (HEIGHT / 2 - PADDLE_HEIGHT / 2);
static paddleRightY: i32 = binding paddleRightYMarker (HEIGHT / 2 - PADDLE_HEIGHT / 2);

static quineStr: &[string] = $quine;

const SPACE_CHAR: char = $quineSpace;
const LINE_CHAR: char = $quineLine;

import "std/print.int";
import "std/string.int";

static idx: i32 = 0;
// Offset 0 is the comma (optional), 1 is the opening quote, and one past the end of the string
// is the closing quote.
static offset: i32 = 0;

/**
  * Tries to print a single character of the quine array, stepping idx and offset forward.
  * Returns true if two characters were printed (needed to escape chars).
  *
  * This uses recursion to skip an offset while still printing out a character in the end.
  */
helper function printQuineArrayChar() -> bool {
    offset = offset + 1;

    if offset == 1 {
        if idx != 0 {
            putchar(',');
        } else {
            return printQuineArrayChar();
        }

        return false;
    }

    if offset == 2 {
        putchar('"');
        return false;
    }

    let c: char = quineStr[idx][offset - 3];

    if c == '\0' {
        putchar('"');
        offset = 0;
        idx = idx + 1;
        return false;
    }

    if c == '"' {
        printf("\\\"");
        return true;
    } else if c == '\\' {
        printf("\\\\");
        return true;
    } else if c != ' ' && c != '\n' {
        putchar(c);
        return false;
    } else {
        return printQuineArrayChar();
    }
}

helper function printQuineArr() {
    // Printing the first character here helps keep the
    // backslashes at the end more consistent.
    printQuineArrayChar();
    putchar('\\');
    putchar('\n');
    // Separator.
    putchar('\\');
    putchar('\n');

    for let row: i32 = 0; row < HEIGHT; row = row + 1; {
        for let col: i32 = 0; col < WIDTH; col = col + 1; {
            if idx >= $quineLen || (col >= ballX && row >= ballY && col - ballX < BALL_RADIUS && row - ballY < BALL_RADIUS)
               || (col >= PADDLE_LEFT_X && row >= paddleLeftY && col - PADDLE_LEFT_X < PADDLE_WIDTH && row - paddleLeftY < PADDLE_HEIGHT)
               || (col >= PADDLE_RIGHT_X && row >= paddleRightY && col - PADDLE_RIGHT_X < PADDLE_WIDTH && row - paddleRightY < PADDLE_HEIGHT)
            {
                putchar(' ');
            } else {
            if printQuineArrayChar() {
                    col = col + 1;
                }
            }
        }

        // Offset 0 means we aren't in a string literal,
        // so we need a backslash to continue it.
        if offset != 0 {
            putchar('\\');
        }
        putchar('\n');
    }

    // Separator.
    if offset != 0 {
        putchar('\\');
    }
    putchar('\n');

    // Print the remaining characters.
    while idx < $quineLen {
        printQuineArrayChar();
    }
}

helper function printQuineItem(s: string) {
    // This is the quine part of the string if it's completely
    // empty, except for spaces and newlines.
    let quinePart: bool = true;
    for let i: i32 = 0; s[i] != '\0'; i = i + 1; {
        if s[i] == $quineSpace {
            putchar(' ');
        } else if s[i] == $quineLine {
            putchar('\n');
        } else if s[i] != ' ' && s[i] != '\n' {
            quinePart = false;
            putchar(s[i]);
        }
    }

    if quinePart {
        printQuineArr();
    }
}

helper function printQuine1() {
    for let i: i32 = 0; i < $quineLen; i = i + 1; {
        printQuineItem(quineStr[i]);
    }

    // A trailing newline is needed for valid C.
    putchar('\n');
}

function main(argc: i32, argv: &[string]) -> i32 {
    // Compute next ball position.
    let newBallX: i32 = ballX + ballSpeedX;
    let newBallY: i32 = ballY + ballSpeedY;

    // Paddle bounce.
    //
    // This is optimized for the sides that will actually be hit,
    // so if the ball hits the left paddle while moving right,
    // it will phase through.
    if (newBallX >= PADDLE_LEFT_X && newBallX < PADDLE_LEFT_X + PADDLE_WIDTH && newBallY + BALL_RADIUS > paddleLeftY && newBallY < paddleLeftY + PADDLE_HEIGHT)
       || (newBallX + BALL_RADIUS > PADDLE_RIGHT_X && newBallX < PADDLE_RIGHT_X + PADDLE_WIDTH && newBallY + BALL_RADIUS > paddleRightY && newBallY < paddleRightY + PADDLE_HEIGHT)
    {
        newBallX = newBallX - ballSpeedX;
        ballSpeedX = -1 * ballSpeedX;
    }

    // Left and right walls means a player lost.
    if newBallX < 0 || newBallX > WIDTH - BALL_RADIUS {
        newBallX = WIDTH / 2 - BALL_RADIUS / 2;
        newBallY = HEIGHT / 2 - BALL_RADIUS / 2;
    }

    // Top and bottom walls should bounce.
    if newBallY < 0 || newBallY > HEIGHT - BALL_RADIUS {
        newBallY = newBallY - ballSpeedY;
        ballSpeedY = -1 * ballSpeedY;
    }

    // Compute paddle updates.
    let newPaddleRightY: i32 = paddleRightY;

    if argc > 1 {
        if argv[1][0] == 'w' && newPaddleRightY > 0 {
            newPaddleRightY = newPaddleRightY - 1;
        } else if argv[1][0] == 's' && newPaddleRightY < HEIGHT - PADDLE_HEIGHT {
            newPaddleRightY = newPaddleRightY + 1;
        }
    }

    quineStr[ballXMarker] = string(newBallX);
    quineStr[ballYMarker] = string(newBallY);
    quineStr[ballSpeedXMarker] = string(ballSpeedX);
    quineStr[ballSpeedYMarker] = string(ballSpeedY);
    quineStr[paddleRightYMarker] = string(newPaddleRightY);
    printQuine1();
}

// - Set the array to empty values.
// - Copy the left and right size (up to and including "{" or "}").
// - Escape them for a string (escape \, ", and \n).
// - Put the escaped strings into the array.
static quineStr: &[string] = ["#include<stdio.h>\nvoid b(char*e){int f;f=0;while(1){if(e[f]=='\\0'){break;}if(e[f]=='\"'){printf(\"\\\\\\\"\");}else{if(e[f]=='\\n'){printf(\"\\\\n\");}else{if(e[f]=='\\\\'){printf(\"\\\\\\\\\");}else{putchar(e[f]);}}}f=f+1;}}void c(char* *e,int f){int g;g=0;while(1){if(g>=f){break;}if(g!=0){putchar(',');}putchar('\"');b(e[g]);putchar('\"');g=g+1;}}void d(char* *e,int f){int g;g=0;while(1){if(g>=f){break;}if(e[g][0]=='\\0'){c(e,f);}else{printf(\"%s\",e[g]);}g=g+1;}}static char*a[]={", "", "};void main(){d(a,3);}"];

function main() {
    printQuine(quineStr, 3);
}
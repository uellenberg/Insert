// This file is all imaginary, and used to plan out the compiler.
// This is a quine which generates an animated ball that falls from the top to the bottom of the screen.

// This places 0 in the compiled (and interpreted) code, but
// during quine output, creates a binding that can be used to replace
// the value.
// This binding is equivalent to a marker.
static ball_y: u32 = binding!(BALL_Y, 0);

// These values will have to be fiddled with a bit.
// Too small, and they'll cause an error.
const SCREEN_WIDTH: u32 = 10;
const SCREEN_HEIGHT: u32 = 10;
const BALL_SIZE: u32 = 4;
const BALL_SPACE: string = "    ";
const BALL_PADDING: string = "/**/";
const LEFT_SIZE: u32 = (SCREEN_WIDTH - BALL_SIZE) / 2;
const RIGHT_SIZE: u32 = SCREEN_WIDTH - LEFT_SIZE - BALL_SIZE;

// This splits tokens into a new chunk at this position, and allows referencing it later.
// This makes it accessible when outputting the quine, and can be used as an offset.
//
// START and END are special markers that refer to the first and last chunks respectively.
marker!(MAIN);

function main() {
    // A quine statement can only be used once in the program.
    // It splits the parent chunk, and handles building the self-referential part
    // of the output automatically.
    //
    // It creates a string variable, output.
    quine output = (offset, text) {
        // offset refers to the chunk offset within the marker.
        // If we do marker!(CHUNK), then later chunk!(CHUNK, 2), and chunk!(CHUNK, 3),
        // then CHUNK + 0 refers to the first two characters after the marker, CHUNK + 1
        // refers to the third character, and CHUNK + 2 refers to the rest until the next chunk.

        BALL_Y => {
            text = string(min(SCREEN_HEIGHT - BALL_SIZE, ball_y + 1));
        },
        MAIN => {
            if offset % 2 == 1 {
                if (offset / 2) >= ball_y && (offset / 2) < ball_y + BALL_SIZE {
                    text = BALL_SPACE + text;
                } else {
                    text = text + BALL_PADDING;
                }
            }
        }
    };

    print(output);
}

// All the code between START and this line now lives in the END chunk.
marker!(MAIN_END);

// Certain basic operations (like binding and chunk above) are allowed to be used freely, but
// when using the full language to establish information about the output code, we need to tell
// the compiler that this is compile-time only. That means anything in here will never be output.
comp! {
    // This is in function-scope.
    // Functions cannot be created in here (but you can do them outside as inline functions).
    // We also cannot access statics, as it would lead to subtle bugs.
    //
    // Here, we want to segment the main section into two chunks per line:
    // |    left    |    right    +    ball    |
    //
    // Then, the right segment can be shifted to make way for the ball, and extra
    // padding can be added to the end otherwise (for a consistent width).
    //
    // To do that, we can instruct the compiler to insert a new marker at a character offset.
    for (let i: u32 = 0; i < SCREEN_HEIGHT; i += 1) {
        let offset = i * SCREEN_WIDTH;
        // Chunks are identified by marker + offset.
        // Because MAIN + offset 0 was already created above, this
        // is a no-op for the first line.
        //
        // Tokens have certain boundaries which restrict where they can be split
        // at.
        // If we try, we'll get an error.
        // I need a working compiler first to figure out the best solution, but it
        // will involve some way to automatically specify padding.
        chunk!(MAIN, offset);
        chunk!(MAIN, offset + LEFT_SIZE);
    }
}
#include<stdio.h>
static int a=0;static char*b[]={"#include<stdio.h>\nstatic int a=","0",";static char*b[]={","","};void c(char*f){int g;for(g=0;f[g]!='\\0';g=g+1)if(f[g]=='\"')printf(\"\\\\\\\"\");else if(f[g]=='\\n')printf(\"\\\\n\");else if(f[g]=='\\\\')printf(\"\\\\\\\\\");else putchar(f[g]);}void d(char* *f,int g){int h;for(h=0;h<g;h=h+1){if(h!=0)putchar(',');putchar('\"');c(f[h]);putchar('\"');}}void e(char* *f,int g){int h;for(h=0;h<g;h=h+1)if(f[h][0]=='\\0')d(f,g);else printf(\"%s\",f[h]);}void main(){char*f;int g=a+1;asprintf(&f,\"%i\",g);b[1]=f;e(b,","7",");}"};void c(char*f){int g;for(g=0;f[g]!='\0';g=g+1)if(f[g]=='"')printf("\\\"");else if(f[g]=='\n')printf("\\n");else if(f[g]=='\\')printf("\\\\");else putchar(f[g]);}void d(char* *f,int g){int h;for(h=0;h<g;h=h+1){if(h!=0)putchar(',');putchar('"');c(f[h]);putchar('"');}}void e(char* *f,int g){int h;for(h=0;h<g;h=h+1)if(f[h][0]=='\0')d(f,g);else printf("%s",f[h]);}void main(){char*f;int g=a+1;asprintf(&f,"%i",g);b[1]=f;e(b,7);}
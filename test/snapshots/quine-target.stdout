#include<stdio.h>
static int a=0;static char*b[]={"#include<stdio.h>\nstatic int a=","0",";static char*b[]={","","};void c(char*f){int g;g=0;while(1){if(f[g]=='\\0')break;if(f[g]=='\"')printf(\"\\\\\\\"\");else if(f[g]=='\\n')printf(\"\\\\n\");else if(f[g]=='\\\\')printf(\"\\\\\\\\\");else putchar(f[g]);g=g+1;}}void d(char* *f,int g){int h;h=0;while(1){if(h>=g)break;if(h!=0)putchar(',');putchar('\"');c(f[h]);putchar('\"');h=h+1;}}void e(char* *f,int g){int h;h=0;while(1){if(h>=g)break;if(f[h][0]=='\\0')d(f,g);else printf(\"%s\",f[h]);h=h+1;}}void main(){int f;char*g;f=a+1;asprintf(&g,\"%i\",f);b[1]=g;e(b,","7",");}"};void c(char*f){int g;g=0;while(1){if(f[g]=='\0')break;if(f[g]=='"')printf("\\\"");else if(f[g]=='\n')printf("\\n");else if(f[g]=='\\')printf("\\\\");else putchar(f[g]);g=g+1;}}void d(char* *f,int g){int h;h=0;while(1){if(h>=g)break;if(h!=0)putchar(',');putchar('"');c(f[h]);putchar('"');h=h+1;}}void e(char* *f,int g){int h;h=0;while(1){if(h>=g)break;if(f[h][0]=='\0')d(f,g);else printf("%s",f[h]);h=h+1;}}void main(){int f;char*g;f=a+1;asprintf(&g,"%i",f);b[1]=g;e(b,7);}
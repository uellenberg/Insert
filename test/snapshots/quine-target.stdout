#include<stdio.h>
static int a=0;static char*b[]={"#include<stdio.h>\nstatic int a=","0",";static char*b[]={","","};void c(char*f){int g=0;for(;;){if(f[g]=='\\0')break;if(f[g]=='\"')printf(\"\\\\\\\"\");else if(f[g]=='\\n')printf(\"\\\\n\");else if(f[g]=='\\\\')printf(\"\\\\\\\\\");else putchar(f[g]);g=g+1;}}void d(char* *f,int g){int h=0;for(;;){if(h>=g)break;if(h!=0)putchar(',');putchar('\"');c(f[h]);putchar('\"');h=h+1;}}void e(char* *f,int g){int h=0;for(;;){if(h>=g)break;if(f[h][0]=='\\0')d(f,g);else printf(\"%s\",f[h]);h=h+1;}}void main(){char*f;int g=a+1;asprintf(&f,\"%i\",g);b[1]=f;e(b,","7",");}"};void c(char*f){int g=0;for(;;){if(f[g]=='\0')break;if(f[g]=='"')printf("\\\"");else if(f[g]=='\n')printf("\\n");else if(f[g]=='\\')printf("\\\\");else putchar(f[g]);g=g+1;}}void d(char* *f,int g){int h=0;for(;;){if(h>=g)break;if(h!=0)putchar(',');putchar('"');c(f[h]);putchar('"');h=h+1;}}void e(char* *f,int g){int h=0;for(;;){if(h>=g)break;if(f[h][0]=='\0')d(f,g);else printf("%s",f[h]);h=h+1;}}void main(){char*f;int g=a+1;asprintf(&f,"%i",g);b[1]=f;e(b,7);}
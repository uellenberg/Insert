function main() : () {
    let val (0): u32 = 10;
    let val2 (1): u32 = 10;
    val2 (1) = 20;
    let val3 (2): u32 = 20;
    val2 (1) = 20;
    let val4 (3): u32 = 20;
    loop {
        if (val4 (3) == 30) {

static testVal: i32 = 8;
static testVal2: &i32 = (&testVal);

// Functions: 

function mul(a (0): &i32, b (1): i32) : () {
    let a (0): &i32;
    let b (1): i32;
    (*a (0)) = ((*a (0)) * b (1));
    drop b;
    drop a;
}
function test(val (0): i32) : i32 {
    let val (0): i32;
    let val1 (1): &i32 = (&val (0));
    let val2 (2): i32 = (val (0) + 1);
    let val3 (3): &i32 = (&val2 (2));
    mul(val1 (1), 2)
    mul(val3 (3), 3)
    return ((*val1 (1)) + (*val3 (3)));
    drop val3;
    drop val2;
    drop val1;
    drop val;
}
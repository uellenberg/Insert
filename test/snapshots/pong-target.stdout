#include<stdio.h>
static int a=1;static int b=1;static int c=1;static int d=1;static char*e[]={"#include<stdio.h>\nstatic int a=","1",";static int b=","1",";static int c=","1",";static int d=","1",";static char*e[]={","","};void f(char*i){int j;j=0;while(1){if(i[j]=='\\0')break;if(i[j]=='\"')printf(\"\\\\\\\"\");else if(i[j]=='\\n')printf(\"\\\\n\");else if(i[j]=='\\\\')printf(\"\\\\\\\\\");else putchar(i[j]);j=j+1;}}void g(char* *i,int j){int k;k=0;while(1){if(k>=j)break;if(k!=0)putchar(',');putchar('\"');f(i[k]);putchar('\"');k=k+1;}}void h(char* *i,int j){int k;k=0;while(1){if(k>=j)break;if(i[k][0]=='\\0')g(i,j);else printf(\"%s\",i[k]);k=k+1;}}int main(){int i;int j;int k;char*l;i=a+c;j=b+d;if(i<0||i>77){if(i<0)i=0;else i=77;c=-1*c;}if(j<0||j>7){if(j<0)j=0;else j=7;d=-1*d;}k=i;asprintf(&l,\"%i\",k);e[1]=l;i=j;asprintf(&l,\"%i\",i);e[3]=l;i=c;asprintf(&l,\"%i\",i);e[5]=l;i=d;asprintf(&l,\"%i\",i);e[7]=l;h(e,","13",");printf(\"/*\\n\");i=0;while(1){if(i==10)break;j=0;while(1){if(j==80)break;if(j>=a&&i>=b&&j-a<3&&i-b<3)putchar('#');else putchar(' ');j=j+1;}putchar('\\n');i=i+1;}printf(\"*/\\n\");}"};void f(char*i){int j;j=0;while(1){if(i[j]=='\0')break;if(i[j]=='"')printf("\\\"");else if(i[j]=='\n')printf("\\n");else if(i[j]=='\\')printf("\\\\");else putchar(i[j]);j=j+1;}}void g(char* *i,int j){int k;k=0;while(1){if(k>=j)break;if(k!=0)putchar(',');putchar('"');f(i[k]);putchar('"');k=k+1;}}void h(char* *i,int j){int k;k=0;while(1){if(k>=j)break;if(i[k][0]=='\0')g(i,j);else printf("%s",i[k]);k=k+1;}}int main(){int i;int j;int k;char*l;i=a+c;j=b+d;if(i<0||i>77){if(i<0)i=0;else i=77;c=-1*c;}if(j<0||j>7){if(j<0)j=0;else j=7;d=-1*d;}k=i;asprintf(&l,"%i",k);e[1]=l;i=j;asprintf(&l,"%i",i);e[3]=l;i=c;asprintf(&l,"%i",i);e[5]=l;i=d;asprintf(&l,"%i",i);e[7]=l;h(e,13);printf("/*\n");i=0;while(1){if(i==10)break;j=0;while(1){if(j==80)break;if(j>=a&&i>=b&&j-a<3&&i-b<3)putchar('#');else putchar(' ');j=j+1;}putchar('\n');i=i+1;}printf("*/\n");}
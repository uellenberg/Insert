#include<stdio.h>
static int a=1;static int b=1;static int c=1;static int d=1;static char*e[]={"#include<stdio.h>\nstatic int a=","1",";static int b=","1",";static int c=","1",";static int d=","1",";static char*e[]={","","};void f(char*i){int j;for(j=0;i[j]!='\\0';j=j+1)if(i[j]=='\"')printf(\"\\\\\\\"\");else if(i[j]=='\\n')printf(\"\\\\n\");else if(i[j]=='\\\\')printf(\"\\\\\\\\\");else putchar(i[j]);}void g(char* *i,int j){int k;for(k=0;k<j;k=k+1){if(k!=0)putchar(',');putchar('\"');f(i[k]);putchar('\"');}}void h(char* *i,int j){int k;for(k=0;k<j;k=k+1)if(i[k][0]=='\\0')g(i,j);else printf(\"%s\",i[k]);}int main(){char*i;int j=a+c;int k=b+d;if(j<0||j>77){if(j<0)j=0;else j=77;c=-1*c;}if(k<0||k>7){if(k<0)k=0;else k=7;d=-1*d;}int l=j;asprintf(&i,\"%i\",l);e[1]=i;j=k;asprintf(&i,\"%i\",j);e[3]=i;j=c;asprintf(&i,\"%i\",j);e[5]=i;j=d;asprintf(&i,\"%i\",j);e[7]=i;h(e,","13",");printf(\"/*\\n\");for(j=0;j<10;j=j+1){for(k=0;k<80;k=k+1)if(k>=a&&j>=b&&k-a<3&&j-b<3)putchar('#');else putchar(' ');putchar('\\n');}printf(\"*/\\n\");}"};void f(char*i){int j;for(j=0;i[j]!='\0';j=j+1)if(i[j]=='"')printf("\\\"");else if(i[j]=='\n')printf("\\n");else if(i[j]=='\\')printf("\\\\");else putchar(i[j]);}void g(char* *i,int j){int k;for(k=0;k<j;k=k+1){if(k!=0)putchar(',');putchar('"');f(i[k]);putchar('"');}}void h(char* *i,int j){int k;for(k=0;k<j;k=k+1)if(i[k][0]=='\0')g(i,j);else printf("%s",i[k]);}int main(){char*i;int j=a+c;int k=b+d;if(j<0||j>77){if(j<0)j=0;else j=77;c=-1*c;}if(k<0||k>7){if(k<0)k=0;else k=7;d=-1*d;}int l=j;asprintf(&i,"%i",l);e[1]=i;j=k;asprintf(&i,"%i",j);e[3]=i;j=c;asprintf(&i,"%i",j);e[5]=i;j=d;asprintf(&i,"%i",j);e[7]=i;h(e,13);printf("/*\n");for(j=0;j<10;j=j+1){for(k=0;k<80;k=k+1)if(k>=a&&j>=b&&k-a<3&&j-b<3)putchar('#');else putchar(' ');putchar('\n');}printf("*/\n");}
// Constants: 

const value1: u32 = complexCalculations(10);

// Statics: 

static value: u32 = value1;

// Functions: 

function complexCalculations(a: u32) : u32 {
    let i: u32 = (0 + (0 * 100));
    loop {
        if (i >= a) {
            break;
        }
        i = (i + 1);
    }
    return i;
}
function main() : () {
    let g (0): u32;
    let h (1): bool = true;
    if h (1) {
        g (0) = 10;
    } else {
        if (h (1) == false) {
            g (0) = 20;
        } else {
            g (0) = 30;
        }
    }
    loop {
        if (g (0) == 0) {
            break;
        }
        g (0) = (g (0) - 1);
    }
    drop h;
    drop g;
}
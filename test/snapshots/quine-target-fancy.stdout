#include<stdio.h>
static char*a[]={"#include<stdio.h>\nstatic char*a[]={","","};void b(char*e){\n    int f;\n    f=0;\n    while(1){\n        if(e[f]=='\\0')break;\n        if(e[f]=='\"')printf(\"\\\\\\\"\");\n        else if(e[f]=='\\n')printf(\"\\\\n\");\n        else if(e[f]=='\\\\')printf(\"\\\\\\\\\");\n        else putchar(e[f]);\n        f=f+1;\n    }\n}\nvoid c(char* *e,int f){\n    int g;\n    g=0;\n    while(1){\n        if(g>=f)break;\n        if(g!=0)putchar(',');\n        putchar('\"');\n        b(e[g]);\n        putchar('\"');\n        g=g+1;\n    }\n}\nvoid d(char* *e,int f){\n    int g;\n    g=0;\n    while(1){\n        if(g>=f)break;\n        if(e[g][0]=='\\0')c(e,f);\n        else printf(\"%s\",e[g]);\n        g=g+1;\n    }\n}\nvoid main(){\n    d(a,","5",");\n}\n"};void b(char*e){
    int f;
    f=0;
    while(1){
        if(e[f]=='\0')break;
        if(e[f]=='"')printf("\\\"");
        else if(e[f]=='\n')printf("\\n");
        else if(e[f]=='\\')printf("\\\\");
        else putchar(e[f]);
        f=f+1;
    }
}
void c(char* *e,int f){
    int g;
    g=0;
    while(1){
        if(g>=f)break;
        if(g!=0)putchar(',');
        putchar('"');
        b(e[g]);
        putchar('"');
        g=g+1;
    }
}
void d(char* *e,int f){
    int g;
    g=0;
    while(1){
        if(g>=f)break;
        if(e[g][0]=='\0')c(e,f);
        else printf("%s",e[g]);
        g=g+1;
    }
}
void main(){
    d(a,5);
}
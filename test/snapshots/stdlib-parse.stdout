static test: &[char] = string(10);
inline function string(input: u32) : &[char] {
    let output: string;
    asprintf((&output), "%u", input)
    return output;
}
inline function string(input: i32) : &[char] {
    let output: string;
    asprintf((&output), "%i", input)
    return output;
}
inline function string(input: bool) : &[char] {
    let out: string;
    if input {
        out = "1";
    } else {
        out = "0";
    }
    return out;
}
inline function string(input: &[char]) : &[char] {
    return input;
}
inline function stringInto(input: u32, output: &&[char]) : () {
    asprintf(output, "%u", input)
}
inline function stringInto(input: i32, output: &&[char]) : () {
    asprintf(output, "%i", input)
}
inline function stringInto(input: bool, output: &&[char]) : &[char] {
    if input {
        (*output) = "1";
    } else {
        (*output) = "0";
    }
}
inline function stringInto(input: &[char], output: &&[char]) : () {
    (*output) = input;
}
inline function stringAppend(dest: &[char], source: &[char]) : &[char] {
    return strcat(dest, source);
}
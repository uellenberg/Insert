// Functions: 

inline function string(input (0): u32) : string {
    let input (0): u32;
    let output (1): string;
    asprintf((&output (1)), "%u", input (0))
    return output (1);
}
inline function string(input (0): i32) : string {
    let input (0): i32;
    let output (1): string;
    asprintf((&output (1)), "%i", input (0))
    return output (1);
}
inline function string(input (0): bool) : string {
    let input (0): bool;
    let out (1): string;
    if input (0) {
        out (1) = "true";
    } else {
        out (1) = "false";
    }
    return out (1);
}
inline function string(input (0): string) : string {
    let input (0): string;
    return input (0);
}
extern function asprintf(ptr (0): &string, ...) : () from "<stdio.h>";

function d() : string {
    let g (1): string;
    asprintf((&g (1)), "%u", 10)
    return g (1);
}
function e() : string {
    let g (1): string;
    asprintf((&g (1)), "%i", -10)
    return g (1);
}

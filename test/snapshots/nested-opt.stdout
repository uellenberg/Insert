function main() : () {
    let a (0): i32;
    let b (1): i32;
    let c (2): i32;
    let d (3): i32;
    a (0) = 0;
    loop {
        if (a (0) > 10) {
            break;
        }
        b (1) = 0;
        c (2) = 0;
        loop {
            if (c (2) > 10) {
                break;
            }
            d (3) = 0;
            loop {
                if (d (3) > 10) {
                    break;
                }
                b (1) = (b (1) + d (3));
                d (3) = (d (3) + 1);
            }
            c (2) = (c (2) + 1);
        }
        a (0) = (a (0) + 1);
    }
}
function main() : () {
    let a (1): i32;
    let b (2): i32;
    let c (3): i32;
    let d (0): i32 = 0;
    loop {
        if (d (0) > 10) {
            break;
        }
        a (1) = 0;
        b (2) = 0;
        loop {
            if (b (2) > 10) {
                break;
            }
            c (3) = 0;
            loop {
                if (c (3) > 10) {
                    break;
                }
                a (1) = (a (1) + c (3));
                c (3) = (c (3) + 1);
            }
            b (2) = (b (2) + 1);
        }
        d (0) = (d (0) + 1);
    }
}
// Constants: 

// Statics: 

static str1s: string = string(10);
static str2s: string = string(-10);
static str3s: string = string(true);

// Functions: 

inline function string(input: u32) : string {
    let output: string;
    asprintf((&output), "%u", input)
    return output;
}
inline function string(input: i32) : string {
    let output: string;
    asprintf((&output), "%i", input)
    return output;
}
inline function string(input: bool) : string {
    let out: string;
    if input {
        out = "true";
    } else {
        out = "false";
    }
    return out;
}
inline function string(input: string) : string {
    return input;
}
extern function asprintf(ptr: &string, ...) : () from "<stdio.h>";

function str1() : string {
    return string(10);
}
function str2() : string {
    return string(-10);
}
function str3() : string {
    return string(true);
}
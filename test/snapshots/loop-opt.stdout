// Constants: 

const max: u32 = 10;

// Statics: 

static sum: u32 = 0;

// Functions: 

function main() : () {
    let acc: u32 = 0;
    let i: u32 = 0;
    loop {
        if (i > 10) {
            break;
        }
        acc = (acc + i);
        i = (i + 1);
    }
    sum = acc;
    drop i;
    drop acc;
}
// Constants: 

const max: u32 = 10;

// Statics: 

static sum: u32 = 0;

// Functions: 

function main() : () {
    let acc (0): u32;
    let i (1): u32;
    acc (0) = 0;
    i (1) = 0;
    loop {
        if (i (1) > 10) {
            break;
        }
        acc (0) = (acc (0) + i (1));
        i (1) = (i (1) + 1);
    }
    sum = acc (0);
}
// Constants: 

const max: u32 = 10;

// Statics: 

static a: u32 = 0;

// Functions: 

function main() : () {
    let b (0): u32;
    let c (1): u32;
    b (0) = 0;
    c (1) = 0;
    loop {
        if (c (1) > 10) {
            break;
        }
        b (0) = (b (0) + c (1));
        c (1) = (c (1) + 1);
    }
    a = b (0);
}
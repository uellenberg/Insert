function main() : () {
    let g: u32;
    let h: bool = true;
    if h {
        g = 10;
    } else {
        if (h == false) {
            g = 20;
        } else {
            g = 30;
        }
    }
    loop {
        if (g == 0) {
            break;
        }
        g = (g - 1);
    }
}
function testNestedUse(cond: bool, val1: i32) : i32 {
    let val: i32 = val1;
    if cond {
        if (val != 1) {
            val = 1;
        } else {
            if (val != 2) {
                val = 2;
            }
        }
    }
    return val;
}
// Constants: 

const value1: u32 = 10;

// Statics: 

static value: u32 = 10;

// Functions: 

function complexCalculations(a (0): u32) : u32 {
    let a (0): u32;
    let i (1): u32 = 0;
    loop {
        if (i (1) >= a (0)) {
            break;
        }
        i (1) = (i (1) + 1);
    }
    return i (1);
    drop i;
    drop a;
}
// Constants: 

const value1: u32 = 10;

// Statics: 

static value: u32 = 10;

// Functions: 

function complexCalculations(a: u32) : u32 {
    let a: u32;
    let i: u32 = 0;
    loop {
        if (i >= a) {
            break;
        }
        i = (i + 1);
    }
    return i;
    drop i;
    drop a;
}
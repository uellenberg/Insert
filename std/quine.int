target "C" {
    import "./string.int";
    import "./print.int";

    /** Prints a string, escaped to work within a string literal. */
    helper function printEscaped(s: string) {
        let i: i32 = 0;
        loop {
            if s[i] == '\0' {
                break;
            }

            if s[i] == '"' {
                printf("\\\"");
            } else if s[i] == '\n' {
                printf("\\n");
            } else if s[i] == '\\' {
                printf("\\\\");
            } else {
                putchar(s[i]);
            }

            i = i + 1;
        }
    }

    /** Prints the quine array itself. */
    helper function printQuineArray(strs: &[string], length: i32) {
        let i: i32 = 0;
        loop {
            if i >= length {
                break;
            }

            if i != 0 {
                putchar(',');
            }

            putchar('"');
            printEscaped(strs[i]);
            putchar('"');

            i = i + 1;
        }
    }

    /** Prints the output of the program from the quine array */
    helper function printQuine(strs: &[string], length: i32) {
        let i: i32 = 0;
        loop {
            if i >= length {
                break;
            }

            // Empty string means self-repeating part.
            if strs[i][0] == '\0' {
                printQuineArray(strs, length);
            } else {
                printf("%s", strs[i]);
            }

            i = i + 1;
        }
    }
}